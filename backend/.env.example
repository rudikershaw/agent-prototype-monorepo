# Inference configuration
# Set INFERENCE_MODEL to the model identifier you want to use.
# Use the format "anthropic:<model>" for Anthropic models, "openai:<model>" for OpenAI models, or a bare model name for local LM Studio.
# You can check the Pydantic AI documentation for model name formats. https://pydantic.dev/docs/ai/overview/
# To use providers whose details cannot be automatically implied by Pydantic AI, you will need to set an INFERENCE_HOST variable.

# Google provides free API keys. I will provide my key when I submit the task.
INFERENCE_MODEL=google:gemini-2.5-flash
GEMINI_API_KEY=XYZ

